{
  "pollIntervalSeconds": 300,
  "githubTokenEnvVar": "GITHUB_TOKEN",
  "repositories": [
    {
      "id": "example-app",
      "name": "Example App",
      "owner": "your-org",
      "repo": "your-app-repo",
      "branch": "main",
      "localCheckoutPath": "~/Developer/ExampleApp",
      "workingDirectory": "~/Developer/ExampleApp",
      "buildOnFirstSeen": false,
      "buildMode": "xcodeArchive",
      "xcode": {
        "projectPath": "~/Developer/ExampleApp/ExampleApp.xcodeproj",
        "workspacePath": null,
        "scheme": "ExampleApp",
        "configuration": "Release",
        "archivePath": "~/Developer/ExampleApp/build/ExampleApp.xcarchive",
        "exportPath": "~/Developer/ExampleApp/build/export",
        "exportOptionsPlistPath": "~/Developer/ExampleApp/ExportOptions.plist",
        "artifactPath": "~/Developer/ExampleApp/build/export/ExampleApp.app"
      },
      "shell": null,
      "publishCommand": "bash \"$SHIPHOOK_BUNDLED_PUBLISH_SCRIPT\" --version \"$SHIPHOOK_VERSION\" --artifact \"$SHIPHOOK_ARTIFACT_PATH\" --app-name \"ExampleApp\" --repo-owner \"$SHIPHOOK_GITHUB_OWNER\" --repo-name \"$SHIPHOOK_GITHUB_REPO\" --release-notes \"$SHIPHOOK_RELEASE_NOTES_PATH\" --docs-dir \"$SHIPHOOK_LOCAL_CHECKOUT_PATH/docs\" --releases-dir \"$SHIPHOOK_LOCAL_CHECKOUT_PATH/release-artifacts\" --working-dir \"$SHIPHOOK_LOCAL_CHECKOUT_PATH\"",
      "releaseNotesPath": "~/Developer/ExampleApp/docs/release-notes/latest.html",
      "githubTokenEnvVar": "GITHUB_TOKEN",
      "environment": {},
      "versionStrategy": "shortSHATimestamp"
    }
  ]
}
